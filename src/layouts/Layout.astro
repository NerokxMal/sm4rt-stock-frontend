---
// Props que cada página puede pasarle al layout.
// "title" es obligatorio, "activePage" sirve para resaltar
// el link activo en el sidebar.
interface Props {
    title: string;
    activePage: 'dashboard' | 'productos' | 'categorias';
}

const { title, activePage } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — sm4rt-stock</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
</head>
<body>
<div class="app">

    <!-- SIDEBAR -->
    <aside class="sidebar">
        <div class="logo">
            <span class="logo-box">SM</span>
            <div class="logo-text">
                <span class="logo-main">4rt</span>
                <span class="logo-sub">stock</span>
            </div>
        </div>

        <nav class="nav">
            <!-- El truco: comparamos activePage con el nombre de cada sección.
                 Si coincide, agregamos la clase "active" que lo resalta. -->
            <a href="/" class={`nav-link ${activePage === 'dashboard' ? 'active' : ''}`}>
                <span class="nav-icon">◈</span>
                <span>Dashboard</span>
            </a>
            <a href="/productos" class={`nav-link ${activePage === 'productos' ? 'active' : ''}`}>
                <span class="nav-icon">▦</span>
                <span>Productos</span>
            </a>
            <a href="/categorias" class={`nav-link ${activePage === 'categorias' ? 'active' : ''}`}>
                <span class="nav-icon">◉</span>
                <span>Categorías</span>
            </a>
        </nav>

        <div class="sidebar-footer">
            <button id="btn-logout" class="btn-logout">
                ⎋ Cerrar sesión
            </button>
            <span class="version">v2.0</span>
        </div>
    </aside>

    <!-- CONTENIDO PRINCIPAL -->
    <main class="main">
        <header class="page-header">
            <h1 class="page-title">{title}</h1>
            <!-- slot nombrado: las páginas pueden inyectar botones aquí -->
            <div class="header-actions">
                <slot name="actions" />
            </div>
        </header>

        <!-- slot principal: aquí va el contenido de cada página -->
        <div class="page-content">
            <slot />
        </div>
    </main>

</div>
<script>
    document.getElementById('btn-logout')?.addEventListener('click', () => {
        // Borramos el token de localStorage
        localStorage.removeItem('token');
        // Borramos la cookie poniendo una fecha de expiración en el pasado
        document.cookie = 'token=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/;';
        // Redirigimos al login
        window.location.href = '/login';
    });
</script>
</body>
</html>

<style is:global>
    /* is:global hace que estos estilos apliquen a toda la app,
       no solo a este componente */

    *, *::before, *::after {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    :root {
        --primary:       #D84910;
        --primary-light: #FF6B35;
        --primary-dim:   rgba(216, 73, 16, 0.12);
        --dark:          #111111;
        --dark-2:        #1A1A1A;
        --dark-3:        #242424;
        --light:         #F5F2EE;
        --light-2:       #EDEAE5;
        --text:          #1A1A1A;
        --text-muted:    #888880;
        --border:        #E0DDD8;
        --success:       #2E7D32;
        --success-bg:    #E8F5E9;
        --error:         #C62828;
        --error-bg:      #FFEBEE;
        --warning:       #E65100;
        --warning-bg:    #FFF3E0;

        --font-mono: 'Space Mono', monospace;
        --font-sans: 'DM Sans', sans-serif;

        --sidebar-width: 240px;
        --radius: 6px;
        --shadow: 0 2px 8px rgba(0,0,0,0.08);
    }

    body {
        font-family: var(--font-sans);
        background: var(--light);
        color: var(--text);
        font-size: 15px;
        line-height: 1.5;
    }

    /* ─── LAYOUT ──────────────────────────────────────────────── */

    .app {
        display: flex;
        min-height: 100vh;
    }

    /* ─── SIDEBAR ─────────────────────────────────────────────── */

    .sidebar {
        width: var(--sidebar-width);
        background: var(--dark);
        display: flex;
        flex-direction: column;
        padding: 28px 16px;
        position: fixed;
        top: 0;
        left: 0;
        height: 100vh;
        z-index: 100;
    }

    .logo {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 40px;
        padding: 0 8px;
    }

    .logo-box {
        /* El cuadro naranja con las iniciales */
        background: var(--primary);
        color: white;
        font-family: var(--font-mono);
        font-weight: 700;
        font-size: 13px;
        width: 36px;
        height: 36px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 4px;
        letter-spacing: 1px;
    }

    .logo-text {
        display: flex;
        flex-direction: column;
        line-height: 1.1;
    }

    .logo-main {
        font-family: var(--font-mono);
        font-size: 18px;
        font-weight: 700;
        color: white;
    }

    .logo-sub {
        font-family: var(--font-sans);
        font-size: 11px;
        color: var(--primary);
        letter-spacing: 2px;
        text-transform: uppercase;
        font-weight: 500;
    }

    .nav {
        display: flex;
        flex-direction: column;
        gap: 4px;
        flex: 1;
    }

    .nav-link {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px 12px;
        border-radius: var(--radius);
        text-decoration: none;
        color: #888;
        font-size: 14px;
        font-weight: 500;
        transition: all 0.15s ease;
        letter-spacing: 0.2px;
    }

    .nav-link:hover {
        color: white;
        background: var(--dark-3);
    }

    .nav-link.active {
        color: white;
        background: var(--primary);
    }

    .nav-icon {
        font-size: 16px;
        width: 20px;
        text-align: center;
        flex-shrink: 0;
    }

    .sidebar-footer {
        padding: 0 8px;
    }

    .version {
        font-family: var(--font-mono);
        font-size: 11px;
        color: #444;
        letter-spacing: 1px;
    }

    /* ─── MAIN ────────────────────────────────────────────────── */

    .main {
        /* margin-left empuja el contenido para que no quede debajo del sidebar fijo */
        margin-left: var(--sidebar-width);
        flex: 1;
        display: flex;
        flex-direction: column;
        min-height: 100vh;
    }

    .page-header {
        background: white;
        padding: 20px 32px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 1px solid var(--border);
        position: sticky;
        top: 0;
        z-index: 50;
    }

    .page-title {
        font-family: var(--font-mono);
        font-size: 20px;
        font-weight: 700;
        letter-spacing: -0.5px;
    }

    .header-actions {
        display: flex;
        gap: 10px;
    }

    .page-content {
        padding: 32px;
        flex: 1;
    }

    /* ─── BOTONES ─────────────────────────────────────────────── */

    .btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 9px 18px;
        border: none;
        border-radius: var(--radius);
        cursor: pointer;
        font-family: var(--font-sans);
        font-size: 14px;
        font-weight: 500;
        text-decoration: none;
        transition: all 0.15s ease;
        white-space: nowrap;
    }

    .btn-primary {
        background: var(--primary);
        color: white;
    }

    .btn-primary:hover {
        background: var(--primary-light);
    }

    .btn-danger {
        background: transparent;
        color: var(--error);
        border: 1px solid #FFCDD2;
    }

    .btn-danger:hover {
        background: var(--error-bg);
    }

    .btn-edit {
        background: transparent;
        color: #1565C0;
        border: 1px solid #BBDEFB;
    }

    .btn-edit:hover {
        background: #E3F2FD;
    }

    .btn-sm {
        padding: 5px 12px;
        font-size: 13px;
    }

    .btn-logout {
        width: 100%;
        padding: 9px 12px;
        background: transparent;
        border: 1px solid #2a2a2a;
        border-radius: var(--radius);
        color: #666;
        font-family: var(--font-sans);
        font-size: 13px;
        cursor: pointer;
        text-align: left;
        margin-bottom: 12px;
        transition: all 0.15s;
    }

    .btn-logout:hover {
        background: var(--dark-3);
        color: white;
        border-color: #333;
    }

    /* ─── TABLAS ──────────────────────────────────────────────── */

    .table-wrapper {
        background: white;
        border-radius: var(--radius);
        border: 1px solid var(--border);
        overflow: hidden;
    }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    thead {
        background: var(--dark);
    }

    th {
        padding: 14px 20px;
        text-align: left;
        font-family: var(--font-mono);
        font-size: 11px;
        font-weight: 700;
        color: #888;
        letter-spacing: 1px;
        text-transform: uppercase;
    }

    td {
        padding: 14px 20px;
        border-bottom: 1px solid var(--border);
        font-size: 14px;
    }

    tbody tr:last-child td {
        border-bottom: none;
    }

    tbody tr:hover {
        background: var(--light);
    }

    .actions-cell {
        display: flex;
        gap: 6px;
    }

    /* ─── TARJETAS DASHBOARD ──────────────────────────────────── */

    .cards-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 20px;
        margin-bottom: 32px;
    }

    .card {
        background: white;
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 24px;
    }

    .card-label {
        font-family: var(--font-mono);
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        color: var(--text-muted);
        margin-bottom: 12px;
    }

    .card-value {
        font-family: var(--font-mono);
        font-size: 36px;
        font-weight: 700;
        color: var(--text);
        line-height: 1;
    }

    .card-value.danger {
        color: var(--primary);
    }

    /* ─── ALERTAS ─────────────────────────────────────────────── */

    .alert {
        padding: 12px 16px;
        border-radius: var(--radius);
        margin-bottom: 20px;
        font-size: 14px;
        font-weight: 500;
    }

    .alert-success {
        background: var(--success-bg);
        color: var(--success);
        border: 1px solid #C8E6C9;
    }

    .alert-error {
        background: var(--error-bg);
        color: var(--error);
        border: 1px solid #FFCDD2;
    }

    /* ─── STOCK ───────────────────────────────────────────────── */

    .stock-ok   { color: var(--success); font-weight: 600; }
    .stock-low  { color: var(--primary); font-weight: 600; }

    /* ─── RESPONSIVE ──────────────────────────────────────────── */

    @media (max-width: 768px) {
        .sidebar {
            width: 100%;
            height: auto;
            position: relative;
            flex-direction: row;
            padding: 12px 16px;
            align-items: center;
        }

        .logo { margin-bottom: 0; margin-right: 20px; }
        .nav  { flex-direction: row; gap: 4px; }
        .sidebar-footer { display: none; }

        .main { margin-left: 0; }

        .page-content { padding: 16px; }
    }
</style>